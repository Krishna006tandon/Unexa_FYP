# MongoDB Configuration
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/database

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=7d

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Server Configuration
PORT=5000
NODE_ENV=development

# Email Configuration (Optional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# Video + Live Streaming (RTMP/HLS via Node-Media-Server)
# IMPORTANT: Most PaaS (Render) do not support exposing RTMP/8000 ports on the same service.
# Run NMS on a separate streaming server in production.
ENABLE_NMS=false
FFMPEG_PATH=ffmpeg
PUBLIC_BASE_URL=http://localhost:5000
RTMP_BASE_URL=rtmp://localhost/live
HLS_BASE_URL=http://localhost:8000
NMS_RTMP_PORT=1935
NMS_HTTP_PORT=8000
NMS_MEDIA_ROOT=

# Video upload processing
VIDEO_TRANSCODE_HLS=false
